# Shepherd Verses — Environment Variables Template
# Copy this file to .env.local (website) and .env (bot)
# Fill in with your actual secrets — NEVER commit real keys to GitHub

# ============================================
# WEBSITE (.env.local in Shepherd-Verses-V2)
# ============================================

# Stripe — Payment Processing
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Supabase — Database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (anon key)

# OpenClaw — (Optional, for cron jobs)
# OPENCLAW_GATEWAY_URL=http://localhost:18789

# ============================================
# TELEGRAM BOT (.env in shepherd-verses-bot)
# ============================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Supabase — Database Access
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (anon key)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (service role key — DO NOT SHARE)

# ElevenLabs — Voice Generation
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE

# Anthropic — Message Generation (Claude API)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_API_KEY_HERE

# Website & Gareth Contact
WEBSITE_URL=https://shepherdverses.com
GARETH_TELEGRAM_ID=8758884128

# ============================================
# OPTIONAL SERVICES (For Future Use)
# ============================================

# Sentry — Error Logging
SENTRY_DSN=https://YOUR_SENTRY_DSN_HERE

# SendGrid / Resend — Email Sending
SENDGRID_API_KEY=SG.YOUR_SENDGRID_KEY_HERE
# OR
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE

# Predis.ai — Social Media Auto-Generation (Future)
PREDIS_API_KEY=YOUR_PREDIS_API_KEY_HERE

# Xero — Accounting Integration (Future)
XERO_CLIENT_ID=YOUR_XERO_CLIENT_ID_HERE
XERO_CLIENT_SECRET=YOUR_XERO_CLIENT_SECRET_HERE

# ============================================
# SECURITY NOTES
# ============================================

# 🔐 CRITICAL:
# 1. NEVER commit real .env files to GitHub
# 2. .env.local and .env are in .gitignore (keep them local)
# 3. Real keys stay on your Mac mini only
# 4. Share ANON_KEY with other devs, NEVER share SECRET keys
# 5. Rotate keys if suspected compromised
# 6. Use .env.example (this file) only for documentation

# 🔑 Key Locations:
# - Stripe: https://dashboard.stripe.com/apikeys
# - Supabase: Project Settings → API
# - ElevenLabs: https://elevenlabs.io/app/settings/api-keys
# - Anthropic: https://console.anthropic.com/account/keys
# - Sentry: https://sentry.io/settings/account/api/auth-tokens/
# - Telegram: Message @BotFather on Telegram

# ✅ Checklist Before Deploying:
# [ ] All real keys are in local .env/.env.local ONLY
# [ ] .env/.env.local files are in .gitignore
# [ ] No real keys in code (use process.env.VAR_NAME)
# [ ] .env.example has placeholders only
# [ ] Vercel/Railway has secrets configured in dashboard
# [ ] Supabase RLS policies are set correctly
# [ ] Stripe webhook endpoint is configured
# [ ] Email service is configured (if using)
